{
  "name": "driver-document-expiry-toolkit",
  "version": "0.1.0",
  "description": "Lightweight TypeScript utilities for driver and vehicle document expiry tracking.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "expiry",
    "documents",
    "drivers",
    "vehicles",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jureteodorovic-glitch/driver-document-expiry-toolkit.git"
  },
  "bugs": {
    "url": "https://github.com/jureteodorovic-glitch/driver-document-expiry-toolkit/issues"
  },
  "homepage": "https://github.com/jureteodorovic-glitch/driver-document-expiry-toolkit#readme",
  "license": "MIT",
  "devDependencies": {
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
